digraph G {
  graph [rankdir=LR, bgcolor="transparent", splines=ortho, nodesep=0.45, ranksep=0.55, margin=0.02];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin="0.08,0.05", color="#334155", penwidth=1.1, fillcolor="#F8FAFC"];
  edge [fontname="Helvetica", fontsize=8, color="#64748B", arrowsize=0.55, penwidth=1.0];
  b0 [label="Brave\nEM 21/100", fillcolor="#FEE2E2", color="#DC2626"];
  b1 [label="visible support\n33 queries", fillcolor="#FFF1F2", color="#DC2626"];
  b2 [label="large snippet-side\nsupport pool\n97 gold URLs", fillcolor="#FFF1F2", color="#DC2626"];
  b3 [label="low contamination\nr_c:g = 0.92", fillcolor="#FFF1F2", color="#DC2626"];
  t0 [label="Tavily\nEM 21/100", fillcolor="#DBEAFE", color="#2563EB"];
  t1 [label="visible support\n24 queries", fillcolor="#EFF6FF", color="#2563EB"];
  t2 [label="rank-1 concentration\n15/31 gold URLs", fillcolor="#EFF6FF", color="#2563EB"];
  t3 [label="fetching gold pays\nSMART EM 64%", fillcolor="#EFF6FF", color="#2563EB"];
  f0 [label="Firecrawl\nEM 23/100", fillcolor="#DCFCE7", color="#16A34A"];
  f1 [label="visible support\n19 queries", fillcolor="#F0FDF4", color="#16A34A"];
  f2 [label="broad exploration\n67 BLIND queries", fillcolor="#F0FDF4", color="#16A34A"];
  f3 [label="high contamination\nr_c:g = 2.59", fillcolor="#F0FDF4", color="#16A34A"];
  b0 -> b1 -> b2 -> b3;
  t0 -> t1 -> t2 -> t3;
  f0 -> f1 -> f2 -> f3;
  { rank=same; b0; t0; f0; }
  { rank=same; b1; t1; f1; }
  { rank=same; b2; t2; f2; }
  { rank=same; b3; t3; f3; }
}
